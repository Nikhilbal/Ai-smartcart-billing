{
  "name": "@smart-cart/mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "build:android:store": "npx eas-cli@latest build --platform android --profile production",
    "build:ios:store": "npx eas-cli@latest build --platform ios --profile production",
    "build:stores": "npx eas-cli@latest build --platform all --profile production",
    "submit:android": "npx eas-cli@latest submit --platform android --profile production",
    "submit:ios": "npx eas-cli@latest submit --platform ios --profile production",
    "submit:stores": "npx eas-cli@latest submit --platform all --profile production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.7.9",
    "expo": "^52.0.23",
    "expo-asset": "~11.0.5",
    "expo-camera": "~16.0.10",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-qrcode-svg": "^6.3.14",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "typescript": "^5.7.2"
  }
}
