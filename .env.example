DATABASE_URL="postgresql://smartcart:smartcart@localhost:5432/smartcart?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
AI_SERVICE_URL="http://localhost:8001"
CORS_ORIGIN="http://localhost:5173,http://localhost:8088"
STORE_ID="mumbai-vile-parle"

# OTP provider
# Use demo locally. For production set OTP_PROVIDER=http and fill provider URL/body/header values.
OTP_PROVIDER="demo"
OTP_EXPOSE_DEMO_OTP="true"
OTP_TTL_SECONDS="300"
OTP_HTTP_URL=""
OTP_HTTP_METHOD="POST"
OTP_HTTP_AUTH_HEADER=""
OTP_HTTP_AUTH_VALUE=""
OTP_HTTP_BODY="{\"mobile\":\"{mobileWithCountryCode}\",\"otp\":\"{otp}\"}"

# Razorpay server keys. Keep the secret only on the backend.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
